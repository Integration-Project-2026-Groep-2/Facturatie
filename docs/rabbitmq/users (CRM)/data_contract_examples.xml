<!-- ==============================================================
     VOORBEELD 1: Bezoeker (privepersoon, geen bedrijf)
     Scenario: inschrijving via frontend, badge nog niet uitgedeeld
     Queue: crm.user.created
============================================================== -->
<user xmlns="https://github.com/Integration-Project-2026-Groep-2/crm/schema/v1">
  <id>a1b2c3d4-e5f6-4789-ab01-cd2345ef6789</id>
  <firstName>Jonas</firstName>
  <lastName>Declercq</lastName>
  <email>jonas.declercq@example.com</email>
  <phone>+32471234567</phone>

  <!-- Adresvelden null: privepersoon, normaal geen factuur -->
  <street      xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
  <houseNumber xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
  <postalCode  xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
  <city        xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
  <country     xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>

  <!-- Geen bedrijf -->
  <companyId xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>

  <role>VISITOR</role>

  <!-- Badge nog niet uitgedeeld -->
  <badgeCode xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>

  <isActive>true</isActive>
  <gdprConsent>true</gdprConsent>
  <createdAt>2026-03-09T10:15:00Z</createdAt>
  <updatedAt>2026-03-09T10:15:00Z</updatedAt>
</user>


<!-- ==============================================================
     VOORBEELD 2: Bedrijfscontact
     Scenario: inschrijving namens bedrijf, companyId verplicht
     Queue: crm.user.created
============================================================== -->
<user xmlns="https://github.com/Integration-Project-2026-Groep-2/crm/schema/v1">
  <id>b2c3d4e5-f6a7-4890-8c12-de3456fa7890</id>
  <firstName>Lien</firstName>
  <lastName>Vermeersch</lastName>
  <email>lien.vermeersch@techbedrijf.be</email>
  <phone>+3225551234</phone>

  <!-- Adresvelden null: factuur gaat naar het bedrijf, niet naar de persoon -->
  <street      xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
  <houseNumber xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
  <postalCode  xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
  <city        xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>
  <country     xsi:nil="true" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"/>

  <!-- COMPANY_CONTACT vereist een companyId -->
  <companyId>c3d4e5f6-a7b8-4901-8d23-ef4567ab8901</companyId>

  <role>COMPANY_CONTACT</role>

  <!-- Badge uitgedeeld aan inkom -->
  <badgeCode>BADGE-2026-00042</badgeCode>

  <isActive>true</isActive>
  <gdprConsent>true</gdprConsent>
  <createdAt>2026-03-09T09:00:00Z</createdAt>
  <updatedAt>2026-03-09T11:30:00Z</updatedAt>
</user>


