<!-- ==============================================================
     VOORBEELD 5: Company aanmaken
     Queue: crm.company.created
============================================================== -->
<company xmlns="https://github.com/Integration-Project-2026-Groep-2/crm/schema/v1">
  <id>c3d4e5f6-a7b8-4901-8d23-ef4567ab8901</id>
  <name>TechBedrijf NV</name>

  <!-- Belgisch formaat: BE + 10 cijfers -->
  <vatNumber>BE0123456789</vatNumber>

  <street>Technologielaan</street>
  <houseNumber>15 bus 3</houseNumber>
  <postalCode>3001</postalCode>
  <city>Leuven</city>
  <country>BE</country>

  <!-- Facturatie-e-mailadres. RFC 5322. -->
  <email>facturatie@techbedrijf.be</email>

  <phone>+3216123456</phone>

  <!-- Hoofdcontactpersoon: verwijzing naar User.id van Lien Vermeersch -->
  <primaryContactId>b2c3d4e5-f6a7-4890-8c12-de3456fa7890</primaryContactId>

  <isActive>true</isActive>
  <createdAt>2026-03-09T08:45:00Z</createdAt>
  <updatedAt>2026-03-09T08:45:00Z</updatedAt>
</company>


